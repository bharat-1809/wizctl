# wizctl configuration

lights: {}
  # Lights are auto-discovered. Example:
  # living_room:
  #   ip: "192.168.1.100"
  #   alias: "Living Room"

groups:
  all: ["*"]
  # bedroom: ["bedroom_main", "bedroom_lamp"]

scenes:
  movie:
    brightness: 20
    temperature: 2700
  reading:
    brightness: 100
    temperature: 4000
  work:
    brightness: 100
    temperature: 6500
  relax:
    brightness: 40
    temperature: 2200
  night:
    brightness: 5
    temperature: 2200
